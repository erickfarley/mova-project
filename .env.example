# MOVA runtime configuration
# Copy this file to ".env" and adjust values for your environment.

# OpenRouter API key (leave empty to use only regex mapping)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model used when OPENROUTER_API_KEY is set
OPENROUTER_MODEL=openrouter/anthropic/claude-3.5-sonnet

# Command mapping strategy:
# LLM   = try OpenRouter first (recommended)
# REGEX = try local regex first
MAPPER_PRIORITY=LLM

# When MAPPER_PRIORITY=LLM:
# 1 = fallback to regex if LLM is unavailable or fails
# 0 = do not fallback (returns HELP if LLM fails)
LLM_FALLBACK_REGEX=1

# Audio backend selection:
# 1 = force sounddevice (recommended when PyAudio is not installed)
# 0 = prefer PyAudio when available
FORCE_SD=1
